# ============================================
# NODE MODULES (DO NOT PUSH - TOO LARGE)
# ============================================
node_modules/
**/node_modules/

# ============================================
# ENVIRONMENT VARIABLES (SECURITY RISK)
# ============================================
.env
.env.local
.env.*.local

# ============================================
# LOGS
# ============================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ============================================
# BACKEND CACHES
# ============================================
b/.cache/
f/r/.cache/
**/.cache/

# ============================================
# OPERATING SYSTEM FILES
# ============================================
.DS_Store
Thumbs.db
*.swp
*.swo
*~

# ============================================
# IDE / EDITOR FILES
# ============================================
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ============================================
# REACT BUILD FOLDER
# ============================================
f/r/build/
build/

# ============================================
# PACKAGE LOCK FILES (OPTIONAL - KEEP IF YOU WANT)
# ============================================
# Uncomment the lines below if you DON'T want to push lock files
# package-lock.json
# **/package-lock.json

# ============================================
# TEST COVERAGE REPORTS
# ============================================
coverage/

# ============================================
# PYTHON (if you had any scripts)
# ============================================
__pycache__/
*.pyc

# ============================================
# TEMPORARY / MISC FILES
# ============================================
*.tmp
temp/
tmp/